# ──────────────────────────────────────────────────────────────────────────────
#  Rzahan Academy — Environment Variables
#  Set these in Netlify → Site configuration → Environment variables
#  NEVER commit actual values to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection string ───────────────────────────────────────────────
# Use the TRANSACTION POOLER URL from Supabase for best serverless performance:
#   Supabase Dashboard → Project Settings → Database → Connection Pooling
#   → Transaction mode → Copy URI (port 6543)
DATABASE_URL=postgresql://postgres.YOURREF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Must be at least 32 characters. Keep this secret — it signs all auth tokens.
SESSION_SECRET=replace-with-a-very-long-random-secret

# ── Production domain (for password-reset link generation) ───────────────────
# Must match the exact domain where your Netlify site is deployed.
SITE_URL=https://your-site-name.netlify.app

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Logging (optional) ───────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Netlify sets this automatically — DO NOT set it manually ─────────────────
# NETLIFY=true
