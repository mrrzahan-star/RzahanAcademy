# ──────────────────────────────────────────────────────────────────
#  Rzahan Academy — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── PostgreSQL connection string (Supabase → Settings → Database → URI) ───────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT signing secret (generate with: openssl rand -base64 64) ───────────────
SESSION_SECRET=change-me-to-a-long-random-secret

# ── Production domain (used in password-reset email links) ────────────────────
SITE_URL=https://your-production-domain.replit.app

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Logging (optional, default: info) ────────────────────────────────────────
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────
# The following are set automatically by Replit workflows.
# Do NOT set them manually unless deploying outside Replit.
# ──────────────────────────────────────────────────────────────────
# PORT=5000
# BASE_PATH=/api
